<!-- homepage.ejs -->
<% extraJS = '/js/landingpage.js' %>

<div class="fraud-marquee">
    <span class="marquee-content">
        <i class="fas fa-exclamation-triangle"></i> Beware of fraud! Use only our official channels. Contact us at +923104308125 for any query.
    </span>
</div>

<section class="hero-banner">
    <div class="container">
        <div class="hero-text">
            <h1>Your Health, Our Priority</h1>
            <p>Get all your medicines and healthcare products delivered at your doorstep</p>
            <a href="#" class="btn-hero">Shop Now →</a>
        </div>
        <div class="hero-image">
            <img src="/images/Surbe20New20banner.webp" alt="Health Products">
        </div>
    </div>
</section>

<section class="categories">
    <div class="container">
        <h2 class="section-title">Categories</h2>
        <div class="category-grid">
            <a href="/products?category=Personal+Care" style="text-decoration:none; color:inherit;">
                <div class="category-card">
                    <img src="/images/ramzan.webp" alt="Ramadan Essentials">
                    <h3>Ramadan Essentials</h3>
                </div>
            </a>
            <a href="/products?category=Cosmetics" style="text-decoration:none; color:inherit;">
                <div class="category-card">
                    <img src="/images/cosmetics.webp" alt="Beauty Care">
                    <h3>Beauty Care</h3>
                </div>
            </a>
            <a href="/products?category=Medicine" style="text-decoration:none; color:inherit;">
                <div class="category-card">
                    <img src="/images/panadol.webp" alt="Medicine">
                    <h3>Medicine</h3>
                </div>
            </a>
            <a href="/products?maxPrice=499" style="text-decoration:none; color:inherit;">
                <div class="category-card">
                    <img src="/images/haleon store.webp" alt="Under Rs.499">
                    <h3>Under Rs.499</h3>
                </div>
            </a>
            <a href="/products?category=Baby+Care" style="text-decoration:none; color:inherit;">
                <div class="category-card">
                    <img src="/images/baby products.webp" alt="Baby Product">
                    <h3>Baby Products</h3>
                </div>
            </a>
            <a href="/products?category=Wellness" style="text-decoration:none; color:inherit;">
                <div class="category-card">
                    <img src="/images/wellness.webp" alt="Wellness">
                    <h3>Wellness</h3>
                </div>
            </a>
        </div>
    </div>
</section>

<section class="brand-showcase">
    <div class="container">
        <div class="image-row">
            <div class="image-card">
                <img src="/images/perfume 2 banner.webp" alt="For Him">
            </div>
            <div class="image-card">
                <img src="/images/perfume banner.webp" alt="For Her">
            </div>
        </div>
        <div class="image-row-single">
            <div class="image-card">
                <img src="/images/final banner image.webp" alt="dvago">
            </div>
        </div>
    </div>
</section>

<section class="featured-products">
    <div class="container">
        <h2 class="section-title">Featured Products</h2>
        <h3 class="category-title">Medicine</h3>
        <div class="products-grid">
            <a href="/products?search=Redoxon" style="text-decoration:none; color:inherit;">
                <div class="product-card">
                    <div class="product-image">
                        <img src="/images/baby products.webp" alt="Redoxon">
                    </div>
                    <div class="product-info">
                        <h4>Redoxon Triple Action Effervescent Orange...</h4>
                        <p class="product-description">Effervescent tablets</p>
                        <div class="price">Rs. 850.00</div>
                    </div>
                </div>
            </a>
            <a href="/products?search=Livity" style="text-decoration:none; color:inherit;">
                <div class="product-card">
                    <div class="product-image">
                        <img src="/images/cosmetics.webp" alt="Livity">
                    </div>
                    <div class="product-info">
                        <h4>Livity Milk Powder Strawberry 400g</h4>
                        <p class="product-description">Milk powder</p>
                        <div class="price">Rs. 2,999.99</div>
                    </div>
                </div>
            </a>
            <a href="/products?search=Gaviscon+Syrup" style="text-decoration:none; color:inherit;">
                <div class="product-card">
                    <div class="product-image">
                        <img src="/images/panadol.webp" alt="Gaviscon Syrup">
                    </div>
                    <div class="product-info">
                        <h4>Gaviscon Syrup 120ml</h4>
                        <p class="product-description">Syrup</p>
                        <div class="price">
                            <span class="current">Rs. 237.50</span>
                            <span class="old">Rs. 250.00</span>
                        </div>
                    </div>
                </div>
            </a>
            <a href="/products?search=Gaviscon+Advance" style="text-decoration:none; color:inherit;">
                <div class="product-card">
                    <div class="product-image">
                        <img src="/images/wellness.webp" alt="Gaviscon Advance">
                    </div>
                    <div class="product-info">
                        <h4>Gaviscon Advance Liquid 120ml</h4>
                        <p class="product-description">Liquid</p>
                        <div class="price">
                            <span class="current">Rs. 361.00</span>
                            <span class="old">Rs. 380.00</span>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>
</section>

<section class="brand-showcase">
    <div class="container">
        <div class="image-row">
            <div class="image-card">
                <img src="/images/perfume 2 banner.webp" alt="For Him">
            </div>
            <div class="image-card">
                <img src="/images/perfume banner.webp" alt="For Her">
            </div>
        </div>
        <div class="image-row-single">
            <div class="image-card">
                <img src="/images/final banner image.webp" alt="dvago">
            </div>
        </div>
    </div>
</section>