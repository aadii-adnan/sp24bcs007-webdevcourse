<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' — DVAGO' : 'DVAGO Pharmacy' %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landingpagestyle.css">
    <!-- Load page-specific CSS if provided -->
    <% if (typeof extraCSS !== 'undefined') { %>
        <link rel="stylesheet" href="<%= extraCSS %>">
    <% } %>
</head>
<body>

    <!-- ===== HEADER ===== -->
    <header class="header">
        <div class="container">
            <div class="logo-area">
                <h1><a href="/" style="text-decoration:none; color:inherit;">DVAGO</a></h1>
                <span>Pharmacy &amp; Wellness Experts</span>
            </div>
            <div class="search-wrapper">
                <form action="/products" method="GET" style="display:contents;">
                    <div class="search-bar">
                        <button type="submit" style="background:none; border:none; cursor:pointer; padding:0;">
                            <i class="fas fa-search"></i>
                        </button>
                        <input type="text" name="search" class="header-search-input" placeholder="Search products...">
                    </div>
                </form>
            </div>
            <div class="header-icons">
                <div class="icon"><i class="far fa-heart"></i></div>
                <div class="icon cart">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-count">0</span>
                </div>
                <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                    <div style="display:flex; align-items:center; gap:10px;">
                        <span style="font-size:13px; font-weight:600; color:#1e3c72;">
                            <i class="fas fa-user-circle" style="color:#f58220;"></i>
                            Hi, <%= currentUser.name.split(' ')[0] %>
                        </span>
                        <% if (currentUser.role === 'admin') { %>
                            <a href="/admin" style="font-size:12px; background:#1e3c72; color:white; padding:6px 12px; border-radius:6px; text-decoration:none; font-weight:600;">
                                <i class="fas fa-cog"></i> Admin
                            </a>
                        <% } %>
                        <a href="/logout" style="font-size:12px; background:#e53935; color:white; padding:6px 12px; border-radius:6px; text-decoration:none; font-weight:600;">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    </div>
                <% } else { %>
                    <div style="display:flex; gap:8px; align-items:center;">
                        <a href="/login" style="font-size:13px; color:#1e3c72; text-decoration:none; font-weight:600; padding:6px 12px; border:1px solid #1e3c72; border-radius:6px;">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                        <a href="/register" style="font-size:13px; background:#f58220; color:white; text-decoration:none; font-weight:600; padding:6px 12px; border-radius:6px;">
                            <i class="fas fa-user-plus"></i> Register
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </header>

    <!-- ===== NAVBAR ===== -->
    <nav class="navbar">
        <div class="container">
            <ul class="nav-menu">
                <li><a href="/" class="<%= typeof activePage !== 'undefined' && activePage === 'home' ? 'active-nav' : '' %>">Home</a></li>
                <li><a href="/products" class="<%= typeof activePage !== 'undefined' && activePage === 'products' ? 'active-nav' : '' %>">Products</a></li>
                <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'admin') { %>
                    <li><a href="/admin" class="<%= typeof activePage !== 'undefined' && activePage === 'admin' ? 'active-nav' : '' %>">Admin Panel</a></li>
                    <li><a href="/sales" class="<%= typeof activePage !== 'undefined' && activePage === 'sales' ? 'active-nav' : '' %>">Sales Dashboard</a></li>
                <% } %>
                <li><a href="/contact-us" class="<%= typeof activePage !== 'undefined' && activePage === 'contact' ? 'active-nav' : '' %>">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <!-- ===== FLASH MESSAGES ===== -->
    <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
        <div style="background:#eaf7ee; color:#2e7d32; border:1px solid #c8e6c9; padding:12px 20px; text-align:center; font-size:14px; font-weight:600;">
            <i class="fas fa-check-circle"></i> <%= success[0] %>
        </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
        <div style="background:#feeeee; color:#e53935; border:1px solid #ffcdd2; padding:12px 20px; text-align:center; font-size:14px; font-weight:600;">
            <i class="fas fa-exclamation-circle"></i> <%= error[0] %>
        </div>
    <% } %>

    <!-- ===== PAGE CONTENT — each page fills this section ===== -->
    <%- body %>

    <!-- ===== FOOTER ===== -->
    <footer class="footer">
        <div class="container">
            <div class="footer-top">
                <div class="footer-logo">
                    <h2>D'VAGO</h2>
                    <span>Pharmacy &amp; Wellness Experts</span>
                </div>
                <p class="trusted-text">Pakistan's most trusted pharmacy chain delivering nationwide</p>
            </div>
        </div>
    </footer>

    <!-- jQuery loaded here so every page can use it -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <!-- Load page-specific JS if provided -->
    <% if (typeof extraJS !== 'undefined') { %>
        <script src="<%= extraJS %>"></script>
    <% } %>

</body>
</html>
