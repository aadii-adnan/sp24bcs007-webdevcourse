<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Product — DVAGO Admin</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">

  <%- include('../partials/adminSidebar', { activePage: 'products' }) %>

  <div class="admin-main">
    <div class="admin-topbar">
      <h1><i class="fas fa-edit" style="margin-right:10px; color:#f58220;"></i>Edit Product</h1>
      <div class="topbar-right">
        <a href="/admin" class="back-to-site">
          <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
      </div>
    </div>

    <div class="admin-content">

      <!-- Success / Error alerts -->
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success">
          <i class="fas fa-check-circle"></i> Product updated successfully!
        </div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error">
          <i class="fas fa-exclamation-circle"></i> <%= error %>
        </div>
      <% } %>

      <div class="admin-form-card">
        <div class="form-card-header">
          <h3><i class="fas fa-box" style="margin-right:8px;"></i>Product Details</h3>
        </div>

        <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" class="form-body">

          <div class="form-row">
            <div class="form-group">
              <label for="name">Product Name *</label>
              <input type="text" id="name" name="name" value="<%= product.name %>" placeholder="e.g. Panadol Extra Tablets 20s" required>
            </div>
            <div class="form-group">
              <label for="category">Category *</label>
              <select id="category" name="category" required>
                <option value="Medicine" <%= product.category === 'Medicine' ? 'selected' : '' %>>Medicine</option>
                <option value="Baby Care" <%= product.category === 'Baby Care' ? 'selected' : '' %>>Baby Care</option>
                <option value="Wellness" <%= product.category === 'Wellness' ? 'selected' : '' %>>Wellness</option>
                <option value="Cosmetics" <%= product.category === 'Cosmetics' ? 'selected' : '' %>>Cosmetics</option>
                <option value="Personal Care" <%= product.category === 'Personal Care' ? 'selected' : '' %>>Personal Care</option>
              </select>
            </div>
          </div>

          <div class="form-row full">
            <div class="form-group">
              <label for="description">Description</label>
              <textarea id="description" name="description" rows="3" placeholder="Short product description..."><%= product.description %></textarea>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="price">Price (Rs.) *</label>
              <input type="number" id="price" name="price" value="<%= product.price %>" placeholder="e.g. 250" min="0" required>
            </div>
            <div class="form-group">
              <label for="stock">Stock Quantity *</label>
              <input type="number" id="stock" name="stock" value="<%= product.stock %>" placeholder="e.g. 100" min="0" required>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="rating">Rating (0 - 5)</label>
              <input type="number" id="rating" name="rating" value="<%= product.rating %>" placeholder="e.g. 4.5" min="0" max="5" step="0.1">
            </div>
            <div class="form-group">
              <label>Current Image</label>
              <img src="<%= product.image %>" class="image-preview" onerror="this.src='https://placehold.co/80x80/eef3fb/1e3c72?text=?'">
              <label for="image">Replace Image</label>
              <input type="file" id="image" name="image" accept="image/jpeg, image/png, image/webp">
              <span class="helper-text">Upload a new image to replace the current one. Leave blank to keep existing image.</span>
            </div>
          </div>

          <div class="form-footer">
            <a href="/admin" class="cancel-link">
              <i class="fas fa-times"></i> Cancel
            </a>
            <button type="submit" class="btn-save">
              <i class="fas fa-save"></i> Update Product
            </button>
          </div>

        </form>
      </div>

    </div>
  </div>
</div>
</body>
</html>
