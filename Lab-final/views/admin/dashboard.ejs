<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — DVAGO</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">

  <%- include('../partials/adminSidebar', { activePage: 'dashboard' }) %>

  <div class="admin-main">

    <!-- Top bar -->
    <div class="admin-topbar">
      <h1><i class="fas fa-tachometer-alt" style="margin-right:10px; color:#f58220;"></i>Dashboard</h1>
      <div class="topbar-right">
        <a href="/products" class="back-to-site" target="_blank">
          <i class="fas fa-external-link-alt"></i> View Site
        </a>
      </div>
    </div>

    <div class="admin-content">

      <!-- Stat Cards -->
      <div class="stat-cards">
        <div class="stat-card" style="border-left-color: #1e3c72;">
          <i class="fas fa-boxes stat-icon"></i>
          <div class="stat-number"><%= totalProducts %></div>
          <div class="stat-label">Total Products</div>
        </div>
        <div class="stat-card" style="border-left-color: #f58220;">
          <i class="fas fa-tags stat-icon"></i>
          <div class="stat-number"><%= totalCategories %></div>
          <div class="stat-label">Categories</div>
        </div>
        <div class="stat-card" style="border-left-color: #e53935;">
          <i class="fas fa-exclamation-triangle stat-icon"></i>
          <div class="stat-number"><%= lowStock %></div>
          <div class="stat-label">Low Stock (under 30)</div>
        </div>
      </div>

      <!-- Products Table -->
      <div class="admin-table-wrap">
        <div class="table-header">
          <h3><i class="fas fa-list" style="margin-right:8px;"></i>All Products (<%= totalProducts %>)</h3>
          <a href="/admin/products/new" class="btn-add-new">
            <i class="fas fa-plus"></i> Add New Product
          </a>
        </div>
        <table class="admin-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Image</th>
              <th>Name</th>
              <th>Category</th>
              <th>Price</th>
              <th>Stock</th>
              <th>Rating</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(function(product, index) { %>
              <tr class="<%= product.stock < 30 ? 'low-stock-row' : '' %>">
                <td><%= index + 1 %></td>
                <td>
                  <img
                    src="<%= product.image %>"
                    alt="<%= product.name %>"
                    style="width:45px; height:45px; object-fit:cover; border-radius:6px; border:1px solid #e4e9f0;"
                    onerror="this.src='https://placehold.co/45x45/eef3fb/1e3c72?text=?'"
                  >
                </td>
                <td style="font-weight:600; max-width:200px;"><%= product.name %></td>
                <td>
                  <span style="background:#eef3fb; color:#1e3c72; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600;">
                    <%= product.category %>
                  </span>
                </td>
                <td style="font-weight:700; color:#1e3c72;">Rs. <%= product.price.toLocaleString() %></td>
                <td>
                  <%= product.stock %>
                  <% if (product.stock < 30) { %>
                    <span class="low-stock-badge">Low</span>
                  <% } %>
                </td>
                <td>
                  <span style="color:#f5a623;">
                    <i class="fas fa-star" style="font-size:12px;"></i>
                  </span>
                  <%= product.rating.toFixed(1) %>
                </td>
                <td>
                  <div class="action-btns">
                    <a href="/admin/products/edit/<%= product._id %>" class="btn-edit">
                      <i class="fas fa-pen"></i> Edit
                    </a>
                    <form action="/admin/products/delete/<%= product._id %>" method="POST" style="display:inline;">
                      <button
                        type="submit"
                        class="btn-delete"
                        onclick="return confirm('Are you sure you want to delete <%= product.name %>? This cannot be undone.')">
                        <i class="fas fa-trash"></i> Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>
</body>
</html>
