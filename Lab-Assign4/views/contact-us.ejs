<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DVAGO — Contact Us</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landingpagestyle.css">
    <link rel="stylesheet" href="/css/responsiveness.css">
    <link rel="stylesheet" href="/css/hamburger.css">
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="logo-area">
                <h1>DVAGO</h1>
                <span>Pharmacy & Wellness Experts</span>
            </div>
            <div class="search-wrapper">
                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search products...">
                </div>
            </div>
            <div class="location-pill">
                <i class="fas fa-map-marker-alt"></i>
                <span>No Address Selected</span>
                <i class="fas fa-chevron-down"></i>
            </div>
            <div class="button-area">
                <button class="btn btn-app"><i class="fas fa-download"></i> Download the App</button>
                <button class="btn btn-instant"><i class="fas fa-bolt"></i> Instant Order</button>
            </div>

            <div class="header-icons">
                <div class="icon">
                    <i class="far fa-heart"></i>
                </div>
                <div class="icon cart">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-count">0</span>
                </div>
                <div class="icon">
                    <i class="far fa-user"></i>
                </div>
            </div>
        </div>
    </header>

    <nav class="navbar">
        <div class="container">
            <ul class="nav-menu">
                <li><a href="/">Home</a></li>
                <li><a href="/products">Products</a></li>
                <li><a href="/contact-us" class="active-nav">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <main class="contact-page" style="padding: 100px 0; background: #fff; text-align: center;">
        <div class="container">
            <h1 style="font-size: 48px; margin-bottom: 20px; color: var(--brand-blue);">Get In Touch</h1>
            <p style="color: var(--text-mid); font-size: 18px; max-width: 600px; margin: 0 auto 40px;">
                Have questions about our products or services? We're here to help! 
                Reach out to us through any of the channels below.
            </p>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px;">
                <div style="background: var(--bg-page); padding: 40px; border-radius: 15px;">
                    <i class="fas fa-phone-alt" style="font-size: 32px; color: var(--brand-orange); margin-bottom: 20px;"></i>
                    <h3 style="margin-bottom: 10px;">Call Us</h3>
                    <p>(021) 11 11 38246</p>
                </div>
                <div style="background: var(--bg-page); padding: 40px; border-radius: 15px;">
                    <i class="fas fa-envelope" style="font-size: 32px; color: var(--brand-orange); margin-bottom: 20px;"></i>
                    <h3 style="margin-bottom: 10px;">Email Us</h3>
                    <p>feedback@dvago.pk</p>
                </div>
                <div style="background: var(--bg-page); padding: 40px; border-radius: 15px;">
                    <i class="fas fa-map-marker-alt" style="font-size: 32px; color: var(--brand-orange); margin-bottom: 20px;"></i>
                    <h3 style="margin-bottom: 10px;">Visit Us</h3>
                    <p>Shaheed-e-Millat Road, Karachi</p>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-top">
                <div class="footer-logo">
                    <h2>D'VAGO</h2>
                    <span>Pharmacy & Wellness Experts</span>
                </div>
                <p class="trusted-text">Pakistan's most trusted pharmacy chain delivering nationwide</p>
                <div class="follow-us">
                    <span>Follow us</span>
                    <div class="social-icons">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-links">
                <div class="footer-col">
                    <h4>Categories</h4>
                    <ul>
                        <li><a href="#">Medicine</a></li>
                        <li><a href="#">Baby & Mother Care</a></li>
                        <li><a href="#">Nutrition & Supplements</a></li>
                        <li><a href="#">Personal Care</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="#">FAQs</a></li>
                        <li><a href="#">Shipping Policy</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                    </ul>
                </div>
                <div class="footer-col" style="grid-column: span 2;">
                    <h4>Official Address</h4>
                    <address style="color: rgba(255,255,255,0.8); font-style: normal; line-height: 1.6;">
                        1st Floor, Plot No. 1 Shaheed-e-Millat Road, Karachi, Pakistan
                    </address>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>